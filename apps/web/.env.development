# COMMITTED FILE. No secrets here. Values are visible to anyone with repo
# access. Note: Vite exposes every VITE_-prefixed var to the browser
# bundle, so treat them as public regardless. Safe defaults for development
# mode. Put sensitive or machine-specific overrides in
# `.env.development.local` (gitignored).

VITE_PORT=5173
VITE_API_URL=/api
